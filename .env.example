# Google OAuth Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Claude API Key
CLAUDE_API_KEY=sk-your-api-key

# Email Configuration
DIGEST_RECIPIENT_EMAIL=your-email@gmail.com
DIGEST_SENDER_NAME=Daily Digest Assistant

# Gmail MCP Settings
GMAIL_LOOK_BACK_HOURS=24
GMAIL_MAX_RESULTS=20

# Calendar Settings
CALENDAR_ID=primary  # Use 'primary' for your main calendar

# Notes Settings
NOTES_TODO_NAME=TODOs
NOTES_PRIORITIES_NAME=Priorities

# Digest Settings
DIGEST_TIMEZONE=America/Los_Angeles  # Adjust to your timezone
INCLUDE_EMAILS=true
INCLUDE_CALENDAR=true
INCLUDE_NOTES=true
